# AUTH-KIT TEMPLATE: Environment Variables
# Target: .env (project root)
# Copy this file to .env and fill in real values before running your app.

# Secret used to sign the session ID cookie.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-random-string

# MongoDB connection string.
MONGODB_URI=mongodb://localhost:27017/myapp

# Server port.
PORT=3000

# Node environment. Set to "production" in deployed environments so that
# secure cookies and other hardening options are enabled automatically.
NODE_ENV=development
